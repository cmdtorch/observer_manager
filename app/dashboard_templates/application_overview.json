      "id": 5,
      "options": {},
      "targets": [
        {
          "datasource": {"type": "tempo", "uid": "tempo"},
          "filters": [{"id": "service-name", "operator": "=", "scope": "resource", "tag": "service.name", "value": "$application", "valueType": "string"}],
          "limit": 20,
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Recent Traces",
      "type": "table"
    }
