  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "mimir"},
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"$application\"}[5m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {}},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "mimir"},
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"$application\",status_code=\"STATUS_CODE_ERROR\"}[5m])) / sum(rate(traces_spanmetrics_calls_total{service=\"$application\"}[5m]))",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {}, "unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "options": {"legend": {"calcs": [], "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "mimir"},
          "expr": "histogram_quantile(0.50, sum(rate(traces_spanmetrics_duration_milliseconds_bucket{service=\"$application\"}[5m])) by (le)) / 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "mimir"},
          "expr": "histogram_quantile(0.95, sum(rate(traces_spanmetrics_duration_milliseconds_bucket{service=\"$application\"}[5m])) by (le)) / 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "mimir"},
          "expr": "histogram_quantile(0.99, sum(rate(traces_spanmetrics_duration_milliseconds_bucket{service=\"$application\"}[5m])) by (le)) / 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Latency (P50/P95/P99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "options": {"dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": false},
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "{application=\"$application\"}",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Recent Logs",
      "type": "logs"
    },
    {
      "datasource": {"type": "tempo", "uid": "tempo"},
