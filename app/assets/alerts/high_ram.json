{
  "title": "High RAM",
  "condition": "C",
  "data": [
    {
      "refId": "A",
      "queryType": "",
      "relativeTimeRange": {"from": 300, "to": 0},
      "datasourceUid": "{{prometheus_uid}}",
      "model": {
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "refId": "A"
      }
    },
    {
      "refId": "B",
      "queryType": "",
      "relativeTimeRange": {"from": 300, "to": 0},
      "datasourceUid": "__expr__",
      "model": {
        "type": "reduce",
        "refId": "B",
        "expression": "A",
        "reducer": "mean",
        "settings": {"mode": ""}
      }
    },
    {
      "refId": "C",
      "queryType": "",
      "relativeTimeRange": {"from": 300, "to": 0},
      "datasourceUid": "__expr__",
      "model": {
        "type": "threshold",
        "refId": "C",
        "expression": "B",
        "conditions": [
          {
            "evaluator": {"params": [85], "type": "gt"},
            "operator": {"type": "and"},
            "query": {"params": ["B"]},
            "reducer": {"params": [], "type": "last"},
            "type": "query"
          }
        ]
      }
    }
  ],
  "for": "5m",
  "ruleGroup": "default",
  "noDataState": "OK",
  "execErrState": "Error"
}
